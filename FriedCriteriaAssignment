# Frailty score and status
# ---------------------------------------------------------------------

def prepare_fried_dataframe(
    df_interview: pd.DataFrame,
    df_pef_ana: pd.DataFrame,
    spec: WaveSpec,
) -> pd.DataFrame:
    """
    Merge the five Fried components from interview and physical-exam files.

    Returns one row per participant and wave.
    """

    interview_cols = [
        "CODE98",
        spec.interview_age_col,
        "weight_loss",
        "exhaustion",
        "low_physical_activity",
    ]
    pef_cols = [
        "CODE98",
        spec.pef_age_col,
        "walking_speed",
        "grip_strength",
    ]

    require_columns(df_interview, interview_cols, "interview file with phenotypes")
    require_columns(df_pef_ana, pef_cols, "PEF analysis file with phenotypes")

    fried = df_pef_ana[pef_cols].merge(
        df_interview[interview_cols],
        on="CODE98",
        how="outer",
    )

    fried["AGE"] = fried[spec.pef_age_col].combine_first(fried[spec.interview_age_col])
    fried = fried[
        ["CODE98", "AGE", *FRAILTY_COMPONENTS]
    ].copy()
    fried["wave"] = spec.name

    return fried


def compute_frailty_count(df: pd.DataFrame) -> pd.Series:
    """
    Count the number of Fried components present.

    Missing/undetermined components coded as 9 are treated as missing.
    Subjects aged <65 are coded as 8.
    """

    components = df[FRAILTY_COMPONENTS].replace(MISSING, np.nan)
    count = components.sum(axis=1, min_count=1)
    count.loc[df["AGE"] < 65] = NOT_APPLICABLE

    return count


def assign_fried_label(count: float | int | pd.NA) -> str:
    """Convert Fried component count into phenotype category."""

    if pd.isna(count):
        return "Undetermined"

    if count == NOT_APPLICABLE:
        return "Not applicable (<65)"

    if count >= 3:
        return "Frail"

    if count >= 1:
        return "Pre-frail"

    if count == 0:
        return "Robust"

    return "Undetermined"


def add_frailty_status(df: pd.DataFrame) -> pd.DataFrame:
    """Add frailty_count and fried_status columns."""

    out = df.copy()
    out["frailty_count"] = compute_frailty_count(out)
    out["fried_status"] = out["frailty_count"].apply(assign_fried_label)
    return out


def keep_complete_frailty_cases(df: pd.DataFrame) -> pd.DataFrame:
    """
    Keep rows with complete information for all five frailty components.

    Components coded as 9 are undetermined and are therefore treated as missing
    before complete-case selection.
    """

    out = df.copy()
    out[FRAILTY_COMPONENTS] = out[FRAILTY_COMPONENTS].replace(MISSING, np.nan)
    return out.dropna(subset=FRAILTY_COMPONENTS).reset_index(drop=True)


# ---------------------------------------------------------------------
# DMO merging
# ---------------------------------------------------------------------

def read_dmo_file(dmo_file: Path) -> pd.DataFrame:
    """
    Read and standardise the DMO file.

    Expected columns:
    - ID: participant identifier, renamed to CODE98.
    - Wave: expected values FU4/FU5, mapped to InCHIANTI wave names.
    """

    if not dmo_file.exists():
        raise FileNotFoundError(f"DMO file not found: {dmo_file}")

    df_dmo = pd.read_csv(dmo_file)

    require_columns(df_dmo, ["ID", "Wave"], "DMO file")

    wave_map = {
        "FU4": "Follow-up4_v2",
        "FU5": "Follow-up5_v1",
    }

    df_dmo = df_dmo.rename(columns={"ID": "CODE98"}).copy()
    df_dmo["wave"] = df_dmo["Wave"].map(wave_map)

    if df_dmo["wave"].isna().any():
        bad_values = sorted(df_dmo.loc[df_dmo["wave"].isna(), "Wave"].dropna().unique())
        raise ValueError(f"Unexpected DMO Wave values: {bad_values}")

    return df_dmo


def merge_dmos(df_fried: pd.DataFrame, df_dmo: pd.DataFrame) -> pd.DataFrame:
    """Merge DMO variables into the Fried frailty dataframe."""

    return df_fried.merge(df_dmo, on=["CODE98", "wave"], how="left")


