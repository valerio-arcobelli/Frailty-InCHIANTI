class WaveSpec:
    """File names and variable prefixes used by each InCHIANTI wave."""

    name: str
    interview_file: str
    pef_ana_file: str
    pef_raw_file: str
    interview_prefix: str
    pef_prefix: str
    letter: str
    interview_age_col: str
