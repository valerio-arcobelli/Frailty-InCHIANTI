def setup_logging() -> None:
    """Configure console logging."""

    logging.basicConfig(
        level=logging.INFO,
        format="%(levelname)s | %(message)s",
    )


def read_sas(path: Path) -> pd.DataFrame:
    """Read a SAS file using latin-1 encoding."""

    if not path.exists():
        raise FileNotFoundError(f"File not found: {path}")

    logging.info("Reading %s", path)
    df, _ = pyreadstat.read_sas7bdat(str(path), encoding="latin1")
    return df


def read_wave_files(base_dir: Path, spec: WaveSpec) -> tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    """
    Read interview, physical-exam analysis, and physical-exam raw files
    for one follow-up wave.

    Parameters
    ----------
    base_dir:
        Root folder containing the wave folders, for example:
        /path/to/InCHIANTI/InCHIANTI 2023
    spec:
        Wave-specific file and prefix configuration.

    Returns
    -------
    tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame]
        interview, physical-exam analysis, physical-exam raw dataframes.
    """

    sas_dir = base_dir / spec.name / "4.Data" / "SAS_Datasets"

    df_interview = read_sas(sas_dir / spec.interview_file)
    df_pef_ana = read_sas(sas_dir / spec.pef_ana_file)
    df_pef_raw = read_sas(sas_dir / spec.pef_raw_file)

    return df_interview, df_pef_ana, df_pef_raw


def replace_undetermined(series: pd.Series) -> pd.Series:
    """Convert the InCHIANTI undetermined code 999 to numeric missing values."""

    return pd.to_numeric(series.replace(999, np.nan), errors="coerce")


def map_sex(series: pd.Series) -> pd.Series:
    """Map numeric sex coding to readable labels."""

    return series.map({1: "Male", 1.0: "Male", 2: "Female", 2.0: "Female"})


def require_columns(df: pd.DataFrame, columns: Iterable[str], dataframe_name: str = "dataframe") -> None:
    """Raise a clear error if required columns are missing."""

    missing = [col for col in columns if col not in df.columns]
    if missing:
        raise KeyError(f"Missing columns in {dataframe_name}: {missing}")


# ---------------------------------------------------------------------
# Fried frailty components
# ---------------------------------------------------------------------

def compute_weight_loss(df_interview: pd.DataFrame, spec: WaveSpec) -> pd.Series:
    """
    Compute the Fried unintentional weight-loss component.

    Rule:
    - 1 if reported weight loss > 4.536 kg and weight loss was not intentional.
    - 9 if information is insufficient or inconsistent.
    - 8 if age < 65 years.
    - 0 otherwise.
    """

    n = spec.interview_prefix
    required = [f"{n}9_V1", f"{n}9_V2", f"{n}8_V31", f"{n}AGE"]
    require_columns(df_interview, required, "interview file")

    weight_change = replace_undetermined(df_interview[f"{n}9_V2"])
    reported_loss = df_interview[f"{n}9_V1"]
    intentionality = df_interview[f"{n}8_V31"]

    result = pd.Series(0, index=df_interview.index, dtype="Int64")
    result.loc[(weight_change > 4.536) & (intentionality != 4)] = 1
    result.loc[(reported_loss != 0) & (reported_loss != 1)] = MISSING
    result.loc[(reported_loss == 1) & (weight_change.isna())] = MISSING
    result.loc[df_interview[f"{n}AGE"] < 65] = NOT_APPLICABLE

    return result


def compute_exhaustion(df_interview: pd.DataFrame, spec: WaveSpec) -> pd.Series:
    """
    Compute the Fried exhaustion component.

    Rule:
    - 1 if either exhaustion item is scored 3 or 4.
    - 9 if both exhaustion items are missing.
    - 8 if age < 65 years.
    - 0 otherwise.
    """

    n = spec.interview_prefix
    required = [f"{n}5_V7", f"{n}5_V20", f"{n}AGE"]
    require_columns(df_interview, required, "interview file")

    item_1 = replace_undetermined(df_interview[f"{n}5_V7"])
    item_2 = replace_undetermined(df_interview[f"{n}5_V20"])

    result = pd.Series(0, index=df_interview.index, dtype="Int64")
    result.loc[item_1.between(3, 4, inclusive="both")] = 1
    result.loc[item_2.between(3, 4, inclusive="both")] = 1
    result.loc[item_1.isna() & item_2.isna()] = MISSING
    result.loc[df_interview[f"{n}AGE"] < 65] = NOT_APPLICABLE

    return result


def compute_low_physical_activity(df_interview: pd.DataFrame, spec: WaveSpec) -> pd.Series:
    """
    Compute the Fried low-physical-activity component.

    Rule:
    - 1 if the physical-activity item is scored 1 or 2.
    - 9 if the item is missing.
    - 8 if age < 65 years.
    - 0 otherwise.
    """

    n = spec.interview_prefix
    required = [f"{n}14_V26", f"{n}AGE"]
    require_columns(df_interview, required, "interview file")

    physical_activity = replace_undetermined(df_interview[f"{n}14_V26"])

    result = pd.Series(0, index=df_interview.index, dtype="Int64")
    result.loc[physical_activity.between(1, 2, inclusive="both")] = 1
    result.loc[physical_activity.isna()] = MISSING
    result.loc[df_interview[f"{n}AGE"] < 65] = NOT_APPLICABLE

    return result


def compute_walk4m(df: pd.DataFrame, prefix: str) -> pd.Series:
    """
    Compute 4-m walking time from the average of two walking trials.

    The multiplier 1.1425 is preserved from the original analysis script.
    """

    required = [f"{prefix}WLK1A", f"{prefix}WLK1B"]
    require_columns(df, required, f"{prefix} walking dataframe")
    return df[required].mean(axis=1) * 1.1425


def assign_height_group(
    df: pd.DataFrame,
    male_median_height: float,
    female_median_height: float,
) -> pd.Series:
    """
    Assign sex-specific height groups used for walking-speed cutoffs.

    Groups:
    - male_below / male_above
    - female_below / female_above
    - unknown
    """

    def _group(row: pd.Series) -> str:
        sex = row["SEX"]
        height = row["HEIGHT"]

        if pd.isna(height):
            return "unknown"

        if sex == "Male":
            return "male_below" if height <= male_median_height else "male_above"

        if sex == "Female":
            return "female_below" if height <= female_median_height else "female_above"

        return "unknown"

    return df.apply(_group, axis=1)


def compute_walking_speed(
    df_pef_ana: pd.DataFrame,
    df_pef_raw: pd.DataFrame,
    df_interview: pd.DataFrame,
    df_baseline_pef_raw: pd.DataFrame,
    df_baseline_pef_ana: pd.DataFrame,
    spec: WaveSpec,
) -> pd.Series:
    """
    Compute the Fried walking-speed/slowness component.

    The follow-up walking time is compared with sex- and height-specific
    80th-percentile cutoffs derived from the baseline population aged 65+.
    Larger walking time means slower performance.

    Rule:
    - 1 if walking time is equal to or above the group-specific 80th percentile.
    - 9 if walking time or cutoff information is missing.
    - 8 if age < 65 years.
    - 0 otherwise.
    """

    n = spec.pef_prefix
    follow_up = df_pef_ana.copy()
    baseline_raw = df_baseline_pef_raw.copy()
    baseline_ana = df_baseline_pef_ana.copy()

    require_columns(follow_up, ["CODE98", "SEX", f"{n}AGE"], "follow-up PEF analysis")
    require_columns(df_pef_raw, ["CODE98", f"{n}1_V21"], "follow-up PEF raw")
    require_columns(df_interview, ["CODE98", f"I{spec.letter}9_Z85"], "follow-up interview")
    require_columns(baseline_raw, ["CODE98", "SEX", "PXAGE", "PX1_V21"], "baseline PEF raw")
    require_columns(baseline_ana, ["CODE98", "SEX", "PXAGE", "PXWLK1A", "PXWLK1B"], "baseline PEF analysis")

    # Restrict baseline reference population to participants aged 65+.
    baseline_raw = baseline_raw.loc[baseline_raw["PXAGE"] >= 65].copy()
    baseline_ana = baseline_ana.loc[baseline_ana["PXAGE"] >= 65].copy()

    # Walking time in follow-up and baseline datasets.
    follow_up["walk4m"] = compute_walk4m(follow_up, n)
    baseline_ana["walk4m"] = compute_walk4m(baseline_ana, "PX")

    # Follow-up sex and height. Height is preferably taken from PEF raw,
    # with interview height used as fallback when PEF raw is missing.
    follow_up["SEX"] = map_sex(follow_up["SEX"])

    height_pef = df_pef_raw[["CODE98", f"{n}1_V21"]].rename(columns={f"{n}1_V21": "HEIGHT"})
    height_interview = df_interview[["CODE98", f"I{spec.letter}9_Z85"]].rename(
        columns={f"I{spec.letter}9_Z85": "HEIGHT"}
    )

    combined_height = height_pef.merge(
        height_interview,
        on="CODE98",
        how="outer",
        suffixes=("_pef", "_interview"),
    )
    combined_height["HEIGHT"] = combined_height["HEIGHT_pef"].combine_first(
        combined_height["HEIGHT_interview"]
    )

    follow_up = follow_up.merge(combined_height[["CODE98", "HEIGHT"]], on="CODE98", how="left")

    # Baseline sex and height.
    baseline_raw["SEX"] = map_sex(baseline_raw["SEX"])
    baseline_ana["SEX"] = map_sex(baseline_ana["SEX"])
    baseline_height_map = baseline_raw.set_index("CODE98")["PX1_V21"]
    baseline_ana["HEIGHT"] = baseline_ana["CODE98"].map(baseline_height_map)

    male_median_height = baseline_raw.loc[baseline_raw["SEX"] == "Male", "PX1_V21"].median()
    female_median_height = baseline_raw.loc[baseline_raw["SEX"] == "Female", "PX1_V21"].median()

    baseline_ana["height_group"] = assign_height_group(
        baseline_ana,
        male_median_height=male_median_height,
        female_median_height=female_median_height,
    )
    follow_up["height_group"] = assign_height_group(
        follow_up,
        male_median_height=male_median_height,
        female_median_height=female_median_height,
    )

    cutoff_by_group = (
        baseline_ana
        .loc[baseline_ana["height_group"].isin(["male_below", "male_above", "female_below", "female_above"])]
        .groupby("height_group")["walk4m"]
        .quantile(0.80)
        .to_dict()
    )

    logging.info("Walking-speed 80th percentile cutoffs: %s", cutoff_by_group)

    result = pd.Series(MISSING, index=follow_up.index, dtype="Int64")
    result.loc[follow_up[f"{n}AGE"] < 65] = NOT_APPLICABLE

    for group, cutoff in cutoff_by_group.items():
        group_mask = (
            (follow_up["height_group"] == group)
            & (follow_up[f"{n}AGE"] >= 65)
            & follow_up["walk4m"].notna()
        )
        result.loc[group_mask] = (follow_up.loc[group_mask, "walk4m"] >= cutoff).astype("Int64")

    return result


def compute_grip(df: pd.DataFrame, prefix: str) -> pd.Series:
    """
    Compute maximum average grip strength across hands.

    Right hand = mean of trials V37 and V39.
    Left hand  = mean of trials V38 and V40.
    Final grip = maximum of right and left hand averages.
    """

    required = [f"{prefix}10_V37", f"{prefix}10_V38", f"{prefix}10_V39", f"{prefix}10_V40"]
    require_columns(df, required, f"{prefix} grip dataframe")

    right = df[[f"{prefix}10_V37", f"{prefix}10_V39"]].mean(axis=1)
    left = df[[f"{prefix}10_V38", f"{prefix}10_V40"]].mean(axis=1)

    return pd.concat([right, left], axis=1).max(axis=1)


def assign_bmi_group(
    df: pd.DataFrame,
    male_quartiles: list[float],
    female_quartiles: list[float],
) -> pd.Series:
    """Assign sex-specific BMI quartile groups."""

    def _group(row: pd.Series) -> str:
        bmi = row["BMI"]
        sex = row["SEX"]

        if pd.isna(bmi):
            return "missing"

        if sex == "Male":
            if bmi <= male_quartiles[0]:
                return "male_q1"
            if bmi <= male_quartiles[1]:
                return "male_q2"
            if bmi <= male_quartiles[2]:
                return "male_q3"
            return "male_q4"

        if sex == "Female":
            if bmi <= female_quartiles[0]:
                return "female_q1"
            if bmi <= female_quartiles[1]:
                return "female_q2"
            if bmi <= female_quartiles[2]:
                return "female_q3"
            return "female_q4"

        return "unknown"

    return df.apply(_group, axis=1)


def compute_grip_strength(
    df_pef_ana: pd.DataFrame,
    df_pef_raw: pd.DataFrame,
    df_baseline_pef_raw: pd.DataFrame,
    df_baseline_pef_ana: pd.DataFrame,
    spec: WaveSpec,
) -> pd.Series:
    """
    Compute the Fried grip-strength/weakness component.

    Follow-up grip strength is compared with sex- and BMI-quartile-specific
    20th-percentile cutoffs derived from the baseline population aged 65+.

    Rule:
    - 1 if grip strength is below the group-specific 20th percentile.
    - 9 if grip strength or cutoff information is missing.
    - 8 if age < 65 years.
    - 0 otherwise.

    When BMI is missing but sex is known, the original script used the
    sex-specific lowest BMI quartile cutoff as fallback; that behaviour is
    preserved here.
    """

    n = spec.pef_prefix
    follow_up = df_pef_ana.copy()
    follow_up_raw = df_pef_raw.copy()
    baseline_raw = df_baseline_pef_raw.copy()
    baseline_ana = df_baseline_pef_ana.copy()

    require_columns(follow_up, ["CODE98", "SEX", f"{n}AGE", f"{n}BMI"], "follow-up PEF analysis")
    require_columns(baseline_ana, ["CODE98", "SEX", "PXAGE", "PXBMI", "PXBMIFLG"], "baseline PEF analysis")
    require_columns(baseline_raw, ["CODE98"], "baseline PEF raw")

    # Compute baseline and follow-up grip.
    baseline_raw["grip"] = compute_grip(baseline_raw, "PX")
    follow_up_raw["grip"] = compute_grip(follow_up_raw, n)

    baseline_ana = baseline_ana.merge(
        baseline_raw[["CODE98", "grip"]],
        on="CODE98",
        how="left",
    )

    # Preserve original BMI flag logic: if PXBMI was flagged as 12,
    # BMI is treated as missing for cutoff derivation.
    baseline_ana.loc[baseline_ana["PXBMIFLG"] == 12, "PXBMI"] = np.nan
    baseline_ana["BMI"] = baseline_ana["PXBMI"]
    baseline_ana["SEX"] = map_sex(baseline_ana["SEX"])
    baseline_ana = baseline_ana.loc[baseline_ana["PXAGE"] >= 65].copy()

    male_quartiles = baseline_ana.loc[baseline_ana["SEX"] == "Male", "BMI"].quantile([0.25, 0.50, 0.75]).tolist()
    female_quartiles = baseline_ana.loc[baseline_ana["SEX"] == "Female", "BMI"].quantile([0.25, 0.50, 0.75]).tolist()

    baseline_ana["bmi_group"] = assign_bmi_group(
        baseline_ana,
        male_quartiles=male_quartiles,
        female_quartiles=female_quartiles,
    )

    cutoff_by_group = (
        baseline_ana
        .loc[baseline_ana["bmi_group"] != "missing"]
        .groupby("bmi_group")["grip"]
        .quantile(0.20)
        .to_dict()
    )

    logging.info("Grip-strength 20th percentile cutoffs: %s", cutoff_by_group)

    # Prepare follow-up dataframe.
    follow_up["SEX"] = map_sex(follow_up["SEX"])
    grip = follow_up_raw[["CODE98", "grip"]]
    follow_up = follow_up.merge(grip, on="CODE98", how="left")
    follow_up["BMI"] = follow_up[f"{n}BMI"]

    follow_up["bmi_group"] = assign_bmi_group(
        follow_up,
        male_quartiles=male_quartiles,
        female_quartiles=female_quartiles,
    )

    result = pd.Series(MISSING, index=follow_up.index, dtype="Int64")
    result.loc[follow_up[f"{n}AGE"] < 65] = NOT_APPLICABLE

    eligible = (follow_up[f"{n}AGE"] >= 65) & follow_up["grip"].notna()

    for group, cutoff in cutoff_by_group.items():
        group_mask = eligible & (follow_up["bmi_group"] == group)
        result.loc[group_mask] = (follow_up.loc[group_mask, "grip"] < cutoff).astype("Int64")

    # Fallback for missing BMI: sex-specific lowest BMI quartile cutoff.
    male_fallback = cutoff_by_group.get("male_q1", np.nan)
    female_fallback = cutoff_by_group.get("female_q1", np.nan)

    male_missing_bmi = eligible & (follow_up["bmi_group"] == "missing") & (follow_up["SEX"] == "Male")
    female_missing_bmi = eligible & (follow_up["bmi_group"] == "missing") & (follow_up["SEX"] == "Female")

    if not pd.isna(male_fallback):
        result.loc[male_missing_bmi] = (follow_up.loc[male_missing_bmi, "grip"] < male_fallback).astype("Int64")

    if not pd.isna(female_fallback):
        result.loc[female_missing_bmi] = (
            follow_up.loc[female_missing_bmi, "grip"] < female_fallback
        ).astype("Int64")

    return result


