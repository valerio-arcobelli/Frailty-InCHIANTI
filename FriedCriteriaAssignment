#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
Compute Fried frailty phenotype components for InCHIANTI follow-up waves.

This script reads InCHIANTI SAS datasets, computes the five Fried frailty
components, derives frailty counts and frailty categories, optionally merges
Digital Mobility Outcomes (DMOs), and can generate exploratory plots.

Authors
-------
Valerio Antonio Arcobelli
Jose Albites Sanabria

Notes
-----
Phenotype coding:
    0 = component absent
    1 = component present
    8 = not applicable, age < 65 years
    9 = undetermined / missing information

The scientific rules implemented here follow the logic used in the original
analysis script. The code has been refactored to avoid global state, local
hard-coded paths, and notebook-style execution order.
"""

from __future__ import annotations

import argparse
import logging
from dataclasses import dataclass
from pathlib import Path
from typing import Iterable

