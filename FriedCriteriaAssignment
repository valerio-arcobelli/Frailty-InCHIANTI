def compute_wave_phenotypes(
    base_dir: Path,
    spec: WaveSpec,
    baseline_pef_raw: pd.DataFrame,
    baseline_pef_ana: pd.DataFrame,
) -> tuple[pd.DataFrame, pd.DataFrame, pd.DataFrame, pd.DataFrame]:
    """
    Read one follow-up wave, compute the five Fried components, and return
    the updated source dataframes plus the merged Fried dataframe.
    """

    df_interview, df_pef_ana, df_pef_raw = read_wave_files(base_dir, spec)

    logging.info("Computing phenotypes for %s", spec.name)

    df_interview = df_interview.copy()
    df_pef_ana = df_pef_ana.copy()

    df_interview["weight_loss"] = compute_weight_loss(df_interview, spec)
    df_interview["exhaustion"] = compute_exhaustion(df_interview, spec)
    df_interview["low_physical_activity"] = compute_low_physical_activity(df_interview, spec)

    df_pef_ana["walking_speed"] = compute_walking_speed(
        df_pef_ana=df_pef_ana,
        df_pef_raw=df_pef_raw,
        df_interview=df_interview,
        df_baseline_pef_raw=baseline_pef_raw,
        df_baseline_pef_ana=baseline_pef_ana,
        spec=spec,
    )
    df_pef_ana["grip_strength"] = compute_grip_strength(
        df_pef_ana=df_pef_ana,
        df_pef_raw=df_pef_raw,
        df_baseline_pef_raw=baseline_pef_raw,
        df_baseline_pef_ana=baseline_pef_ana,
        spec=spec,
    )

    fried = prepare_fried_dataframe(df_interview, df_pef_ana, spec)
    fried = add_frailty_status(fried)

    return df_interview, df_pef_ana, df_pef_raw, fried


def build_fu4_fu5_side_by_side(df_fried: pd.DataFrame) -> pd.DataFrame:
    """Create a side-by-side FU4/FU5 dataframe for longitudinal checks."""

    df_fu4 = df_fried.loc[df_fried["wave"] == "Follow-up4_v2"].copy().add_suffix("_fu4")
    df_fu5 = df_fried.loc[df_fried["wave"] == "Follow-up5_v1"].copy().add_suffix("_fu5")

    return df_fu4.merge(
        df_fu5,
        left_on="CODE98_fu4",
        right_on="CODE98_fu5",
        how="outer",
    )


def run_pipeline(args: argparse.Namespace) -> None:
    """Run the full frailty phenotype pipeline."""

    base_dir = Path(args.base_dir).expanduser().resolve()
    output_dir = Path(args.output_dir).expanduser().resolve()
    output_dir.mkdir(parents=True, exist_ok=True)

    baseline_pef_raw = read_sas(Path(args.baseline_pef_raw).expanduser().resolve())
    baseline_pef_ana = read_sas(Path(args.baseline_pef_ana).expanduser().resolve())

    fried_by_wave = []
    source_data_by_wave = {}

    for wave_name in args.waves:
        spec = WAVES[wave_name]
        df_interview, df_pef_ana, df_pef_raw, fried = compute_wave_phenotypes(
            base_dir=base_dir,
            spec=spec,
            baseline_pef_raw=baseline_pef_raw,
            baseline_pef_ana=baseline_pef_ana,
        )

        fried_by_wave.append(fried)
        source_data_by_wave[wave_name] = {
            "interview": df_interview,
            "pef_ana": df_pef_ana,
            "pef_raw": df_pef_raw,
        }

        if args.validate and wave_name == "Follow-up4_v2":
            validation_dir = output_dir / "validation"
            validation_dir.mkdir(parents=True, exist_ok=True)

            for phenotype in FRAILTY_COMPONENTS:
                source_df = df_interview if phenotype in df_interview.columns else df_pef_ana
                differences = validate_followup4_phenotype(
                    df=source_df,
                    phenotype=phenotype,
                    base_dir=base_dir,
                )
                if differences is not None and not differences.empty:
                    differences.to_csv(validation_dir / f"{phenotype}_differences.csv", index=False)

    df_fried = pd.concat(fried_by_wave, ignore_index=True)
    df_fried = df_fried.drop_duplicates(subset=["CODE98", "wave"])
    df_fried.to_csv(output_dir / "fried_phenotypes_fu4_fu5.csv", index=False)

    df_fried_complete = keep_complete_frailty_cases(df_fried)
    df_fried_complete.to_csv(output_dir / "fried_phenotypes_fu4_fu5_complete_cases.csv", index=False)

    df_side_by_side = build_fu4_fu5_side_by_side(df_fried)
    df_side_by_side.to_csv(output_dir / "fried_phenotypes_fu4_fu5_side_by_side.csv", index=False)

    logging.info("Saved Fried phenotype outputs in %s", output_dir)

    if args.dmo_file:
        df_dmo = read_dmo_file(Path(args.dmo_file).expanduser().resolve())

        df_fried_with_dmo = merge_dmos(df_fried, df_dmo)
        df_fried_with_dmo.to_csv(output_dir / "fried_phenotypes_fu4_fu5_with_dmos.csv", index=False)

        df_complete_with_dmo = merge_dmos(df_fried_complete, df_dmo)
        df_complete_with_dmo.to_csv(output_dir / "fried_phenotypes_fu4_fu5_complete_cases_with_dmos.csv", index=False)

        logging.info("Saved DMO-merged outputs.")

        if args.plot_features:
            plot_dir = output_dir / "figures"
            plot_df = df_complete_with_dmo.loc[df_complete_with_dmo["wave"] == args.plot_wave].copy()
            stats = plot_fried_features(
                df=plot_df,
                features=args.plot_features,
                output_dir=plot_dir,
                show=args.show_plots,
            )
            if not stats.empty:
                stats.to_csv(output_dir / f"fried_status_feature_tests_{args.plot_wave}.csv", index=False)
                logging.info("Saved plots and statistical test table.")


def parse_args() -> argparse.Namespace:
    """Parse command-line arguments."""

    parser = argparse.ArgumentParser(
        description="Compute InCHIANTI Fried frailty phenotypes for FU4 and FU5.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )

    parser.add_argument(
        "--base-dir",
        required=True,
        help="Root folder containing Follow-up4_v2 and Follow-up5_v1 folders.",
    )
    parser.add_argument(
        "--baseline-pef-raw",
        required=True,
        help="Path to baseline Physical_Exam/per_rawe.sas7bdat.",
    )
    parser.add_argument(
        "--baseline-pef-ana",
        required=True,
        help="Path to baseline Physical_Exam/per_ana.sas7bdat.",
    )
    parser.add_argument(
        "--output-dir",
        default="outputs",
        help="Folder where CSV outputs and figures will be saved.",
    )
    parser.add_argument(
        "--waves",
        nargs="+",
        choices=list(WAVES.keys()),
        default=list(WAVES.keys()),
        help="Follow-up waves to process.",
    )
    parser.add_argument(
        "--dmo-file",
        default=None,
        help="Optional DMO CSV file with ID and Wave columns.",
    )
    parser.add_argument(
        "--validate",
        action="store_true",
        help="Validate Follow-up 4 components against adjf4ana.sas7bdat when available.",
    )
    parser.add_argument(
        "--plot-wave",
        choices=list(WAVES.keys()),
        default="Follow-up4_v2",
        help="Wave to use for optional feature plots.",
    )
    parser.add_argument(
        "--plot-features",
        nargs="*",
        default=None,
        help="Optional list of DMO/features to plot by Fried status.",
    )
    parser.add_argument(
        "--show-plots",
        action="store_true",
        help="Display plots interactively in addition to saving them.",
    )

    return parser.parse_args()


def main() -> None:
    """Entry point."""

    setup_logging()
    args = parse_args()
    run_pipeline(args)


if __name__ == "__main__":
    main()
