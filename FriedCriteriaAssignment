# Optional validation against original InCHIANTI adjudicated file
# ---------------------------------------------------------------------

def validate_followup4_phenotype(
    df: pd.DataFrame,
    phenotype: str,
    base_dir: Path,
) -> pd.DataFrame | None:
    """
    Compare a Follow-up 4 computed component with the adjudicated variable.

    This validation is available only for Follow-up 4 because the original
    analysis had the relevant adjudicated file only for that wave.

    Returns
    -------
    pd.DataFrame | None
        A dataframe of discrepancies, or None if validation is unavailable
        or there are no discrepancies.
    """

    phenotype_to_adj_col = {
        "weight_loss": "ACFWGTLS",
        "exhaustion": "ACFEXHAU",
        "low_physical_activity": "ACFPHYAC",
        "walking_speed": "ACFWLKCT",
        "grip_strength": "ACFSTRNC",
    }

    if phenotype not in phenotype_to_adj_col:
        raise ValueError(f"Unknown phenotype: {phenotype}")

    if phenotype not in df.columns:
        raise KeyError(f"{phenotype} not found in dataframe")

    adj_path = base_dir / "Follow-up4_v2" / "4.Data" / "SAS_Datasets" / "Diseases" / "adjf4ana.sas7bdat"
    if not adj_path.exists():
        logging.warning("Validation skipped because adjudicated file was not found: %s", adj_path)
        return None

    df_adj = read_sas(adj_path)
    adj_col = phenotype_to_adj_col[phenotype]

    require_columns(df_adj, ["CODE98", adj_col], "Follow-up 4 adjudicated file")

    comparison = df[["CODE98", phenotype]].merge(
        df_adj[["CODE98", adj_col]],
        on="CODE98",
        how="inner",
    )

    different = comparison[comparison[phenotype] != comparison[adj_col]].copy()

    if different.empty:
        logging.info("%s validation passed: no differences.", phenotype)
        return None

    logging.warning("%s validation found %d differences.", phenotype, len(different))
    return different


